# Copy to .env and fill values. NEVER commit .env to git.
#
# --- Mode ---
# local      = developer machine: use host Postgres/Redis, auto-login as superuser "dev"
# production = remote server: full auth, secrets required, docker compose for DB/cache
APP_ENV=local
PORT=3000
APP_URL=http://localhost:3000

# --- App secrets (production: strong random values; never commit real ones) ---
JWT_SECRET=change-me-to-a-long-random-string

# --- PostgreSQL connection used by the Node app (Prisma) ---
# Local example (existing docker postgres on this machine):
#   postgresql://postgres:postgres@localhost:5432/rasp_poker?schema=public
DATABASE_URL=postgresql://USER:PASSWORD@localhost:5432/rasp_poker?schema=public

# --- Redis connection used by the Node app ---
# If Redis has a password: redis://:PASSWORD@localhost:6379
# Local lims-redis-local uses requirepass — set it only in your private .env
REDIS_URL=redis://:PASSWORD@localhost:6379

# --- Optional local superuser overrides (APP_ENV=local only) ---
LOCAL_DEV_EMAIL=dev@local
LOCAL_DEV_NAME=dev
LOCAL_DEV_PASSWORD=dev

# =============================================================================
# Used ONLY by docker-compose.yml on remote/prod (not needed for local app .env
# if you already have Postgres/Redis running on the host).
# =============================================================================
POSTGRES_USER=
POSTGRES_PASSWORD=
POSTGRES_DB=rasp_poker
POSTGRES_PORT=5432
REDIS_PASSWORD=
REDIS_PORT=6379
