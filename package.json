{
  "name": "rasp-poker",
  "version": "1.0.0",
  "description": "",
  "main": "index.js",
  "scripts": {
    "test": "npm run test:server && npm run test:client",
    "test:server": "jest",
    "test:client": "vitest run --config client/vitest.config.ts",
    "test:e2e": "playwright test",
    "start": "tsx src/index.ts",
    "dev": "concurrently --kill-others-on-fail --names server,client \"npm:dev:server\" \"npm:dev:client\"",
    "dev:server": "tsx watch src/index.ts",
    "dev:client": "vite --config client/vite.config.ts",
    "build": "npm run build:server && npm run build:client",
    "build:server": "tsc",
    "build:client": "tsc -b client/tsconfig.json && vite build --config client/vite.config.ts",
    "typecheck:client": "tsc --noEmit -p client/tsconfig.app.json",
    "lint": "eslint \"src/**/*.ts\" \"client/**/*.ts\" \"client/**/*.tsx\" \"e2e/**/*.ts\" playwright.config.ts",
    "format": "prettier --write .",
    "db:generate": "prisma generate",
    "db:migrate": "prisma migrate deploy",
    "db:migrate:dev": "prisma migrate dev",
    "db:studio": "prisma studio",
    "smoke:bots": "tsx scripts/smoke-bots.ts",
    "bot:solaris": "npm --prefix bot start -- --strategy solaris",
    "bot:grok": "npm --prefix bot start -- --strategy grok",
    "bot:composer": "npm --prefix bot start -- --strategy composer",
    "bot:smoke": "npm --prefix bot run smoke",
    "bot:smoke:solaris": "npm --prefix bot run smoke -- --strategy solaris",
    "bot:smoke:composer": "npm --prefix bot run smoke -- --strategy composer",
    "bot:claude": "tsx bot/src/claude.ts --",
    "bot:claude:sim": "tsx bot/sim/simulate.ts",
    "bot:claude:test": "node --import tsx --test bot/test/ClaudeStrategy.test.ts bot/test/probability.test.ts",
    "mail:test": "tsx scripts/send-test-mail.ts",
    "postinstall": "prisma generate"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/soufee/rasp-poker.git"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "bugs": {
    "url": "https://github.com/soufee/rasp-poker/issues"
  },
  "homepage": "https://github.com/soufee/rasp-poker#readme",
  "dependencies": {
    "@fastify/jwt": "^10.2.0",
    "@fastify/static": "^10.1.0",
    "@fastify/websocket": "^11.3.0",
    "@prisma/client": "^5.22.0",
    "bcryptjs": "^3.0.3",
    "dotenv": "^17.4.2",
    "fastify": "^5.10.0",
    "ioredis": "^5.11.1",
    "nodemailer": "^9.0.3",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "uuid": "^14.0.1"
  },
  "devDependencies": {
    "@playwright/test": "^1.61.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@types/bcryptjs": "^2.4.6",
    "@types/dotenv": "^6.1.1",
    "@types/jest": "^30.0.0",
    "@types/node": "^26.1.1",
    "@types/nodemailer": "^8.0.1",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@types/uuid": "^10.0.0",
    "@types/ws": "^8.18.1",
    "@typescript-eslint/eslint-plugin": "^8.63.0",
    "@typescript-eslint/parser": "^8.63.0",
    "@vitejs/plugin-react-swc": "^4.3.1",
    "concurrently": "^10.0.3",
    "eslint": "^10.7.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-prettier": "^5.5.6",
    "globals": "^17.7.0",
    "jest": "^30.4.2",
    "jsdom": "^29.1.1",
    "playwright": "^1.61.1",
    "prettier": "^3.9.5",
    "prisma": "^5.22.0",
    "ts-jest": "^29.4.11",
    "tsx": "^4.23.1",
    "typescript": "^6.0.3",
    "vite": "^8.1.4",
    "vitest": "^4.1.10",
    "ws": "^8.21.0"
  }
}
